{
  "agents": {
    "defaults": {
      "model": "anthropic/claude-opus-4-6"
    }
  },
  "gateway": {
    "auth": {
      "token": "${OPENCLAW_AUTH_TOKEN}"
    }
  },
  "memory": {
    "backend": "builtin"
  },
  "hooks": {
    "enabled": true,
    "token": "${HOOKS_TOKEN}"
  },
  "channels": {
    "telegram": {
      "dmPolicy": "open",
      "allowFrom": ["*"]
    }
  }
}
