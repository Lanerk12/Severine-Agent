{
  "gateway": {
    "mode": "local",
    "port": 3000
  },
  "agents": {
    "defaults": {
      "model": "anthropic/claude-opus-4-6",
      "workspace": "/root/.openclaw"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "open",
      "allowFrom": ["*"]
    }
  },
  "hooks": {
    "enabled": true,
    "token": "${OPENCLAW_HOOKS_TOKEN}",
    "mappings": [
      {
        "id": "stripe",
        "match": { "path": "stripe" }
      }
    ]
  }
}
