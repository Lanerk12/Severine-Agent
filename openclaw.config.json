{
  "agents": {
    "defaults": {
      "model": "anthropic/claude-opus-4-6",
      "workspace": "/data"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local"
  },
  "memory": {
    "backend": "builtin"
  },
  "channels": {
    "telegram": {
      "dmPolicy": "open",
      "allowFrom": ["*"]
    }
  },
  "internal": {
    "boot-md": {
      "enabled": true
    },
    "session-memory": {
      "enabled": true
    }
  },
  "tools": {
    "browser": {
      "enabled": false
    }
  }
}
